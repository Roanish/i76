{
    // .vscode/c_cpp_properties.json
    // IntelliSense / code intelligence configuration.
    //
    // For VS Code OSS / VSCodium, the best C IntelliSense options are:
    //
    //   OPTION A (recommended): clangd
    //     Extension: llvm-vs-code-extensions.vscode-clangd  (Open VSX)
    //     Install clangd: sudo apt install clangd
    //     Uses compile_commands.json generated by CMake
    //     (CMAKE_EXPORT_COMPILE_COMMANDS=ON is set in tasks.json).
    //     With clangd you may not need this file at all — it reads
    //     compile_commands.json directly from the build/ folder.
    //
    //   OPTION B: ms-vscode.cpptools
    //     Available on Open VSX. Uses this file for configuration.
    //
    // This file covers Option B. If using clangd, this file is ignored
    // but harmless to keep around.
    "version": 4,
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/src",
                "${workspaceFolder}/src/**",
                // SDL2 headers — standard location on Ubuntu/Debian
                // If SDL2 is somewhere else, update this path.
                "/usr/include/SDL2"
            ],
            "defines": [],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c11",
            "cppStandard": "c17",
            // Point at the compile_commands.json that CMake generates.
            // This gives IntelliSense the exact flags used to build each file.
            "compileCommands": "${workspaceFolder}/build/compile_commands.json",
            "intelliSenseMode": "linux-gcc-x64"
        }
    ]
}
